DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

REMOTE_BACKUP_MODE=none
REMOTE_SSH_HOST=backup.example.com
REMOTE_SSH_USER=backupuser
REMOTE_SSH_PORT=22
REMOTE_SSH_PATH=/srv/backups/ci3
FTP_HOST=ftp.example.com
FTP_USER=ftp_user
FTP_PASS=ftp_password
FTP_PORT=21
FTP_PATH=/ci3
FTP_SSL=false
REMOTE_KEEP_LOCAL=true
VERIFY_BACKUP=true
